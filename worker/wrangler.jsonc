{
  "$schema": "../node_modules/wrangler/config-schema.json",
  "name": "property-pal-api",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-04",
  "observability": {
    "enabled": true
  },
  "vars": {
    "CORS_ORIGIN": "https://jopka.pp.ua/"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "jopka_korp",
      "database_id": "aecbbe66-d30e-4d8a-926a-cfcb1d804562"
    }
  ]
}
